# Backend base URL — used when Vite proxy is not available (e.g. static build).
# In development, Vite proxy (/api -> C# gateway) is used automatically.
# VITE_API_BASE_URL=http://127.0.0.1:8001

# C# gateway client API key (leave empty if gateway auth is disabled).
# VITE_GATEWAY_API_KEY=dev-client-key
